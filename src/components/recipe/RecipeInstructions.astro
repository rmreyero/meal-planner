---
import SectionHeading from '@/components/ui/SectionHeading.vue';
import IconRestaurant from '~icons/material-symbols/restaurant';

interface Props {
  instructions: string[];
}

const { instructions } = Astro.props;

let stepCounter = 0;
---

<section class="py-8">
  <SectionHeading>
    <IconRestaurant slot="icon" class="w-6 h-6" />
    Paso a Paso
  </SectionHeading>
  <div class="space-y-8">
    {instructions.map((step) => {
      if (step.startsWith('[')) {
        return (
          <h3 class="font-bold text-primary mt-2">{step.replace(/[\[\]]/g, '')}</h3>
        );
      }
      stepCounter++;
      return (
        <div class="flex gap-4">
          <span class="flex-shrink-0 size-8 bg-primary text-white rounded-full flex items-center justify-center font-bold text-sm shadow-sm shadow-primary/30">
            {stepCounter}
          </span>
          <p class="text-slate-600 text-sm leading-relaxed pt-1">{step}</p>
        </div>
      );
    })}
  </div>
</section>
