---
import Layout from '../../layouts/Layout.astro';
import MacroCalculator from '../../components/MacroCalculator.vue';
import FavoriteButton from '../../components/FavoriteButton.vue';
import { db, schema } from '../../../db/index';
import { eq } from 'drizzle-orm';
import type { IngredientGroup } from '../../../db/schema';

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/');
}

const recipe = db.select().from(schema.recipes).where(eq(schema.recipes.slug, slug)).get();

if (!recipe) {
  return Astro.redirect('/');
}

const ingredients = recipe.ingredients as IngredientGroup[];
const instructions = recipe.instructions as string[];
const notes = recipe.notes as string[] | null;
const hasMacros = recipe.baseCalories && recipe.basePortionWeight;
const tags = (recipe.tags as string[] | null) ?? [];

const timeItems = [
  recipe.prepTime && { label: 'Prep', value: recipe.prepTime },
  recipe.cookTime && { label: 'Coccion', value: recipe.cookTime },
  recipe.totalTime && { label: 'Total', value: recipe.totalTime },
].filter(Boolean) as { label: string; value: string }[];
---

<Layout title={recipe.name}>
  <!-- Mobile back + favorite header -->
  <div class="flex items-center justify-between mb-3 md:hidden">
    <a href="/" class="flex size-10 items-center justify-center rounded-full hover:bg-primary/10 transition-colors">
      <span class="material-symbols-outlined">arrow_back</span>
    </a>
    <FavoriteButton client:load recipeId={recipe.id} initial={!!recipe.isFavorite} />
  </div>

  <!-- Hero image -->
  {recipe.photoPath && (
    <div class="mb-4 md:mb-0">
      <img
        src={`/photos/${recipe.photoPath}?w=800&f=webp`}
        alt={recipe.name}
        class="w-full rounded-xl object-cover max-h-64 md:max-h-80 shadow-lg"
      />
    </div>
  )}

  <!-- Desktop: grid layout -->
  <div class="md:grid md:grid-cols-12 md:gap-8 md:mt-8">
    <!-- Left column (mobile: full width, desktop: 7 cols) -->
    <div class="md:col-span-7">
      <!-- Title & meta -->
      <div class="mt-4 md:mt-0 mb-4">
        <div class="flex items-start justify-between">
          <h1 class="text-2xl md:text-3xl font-extrabold leading-tight">{recipe.name}</h1>
          <div class="hidden md:block">
            <FavoriteButton client:load recipeId={recipe.id} initial={!!recipe.isFavorite} />
          </div>
        </div>

        {tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-3">
            {tags.map((tag) => (
              <span class="px-3 py-1 bg-primary/10 text-primary rounded-full text-xs font-bold uppercase tracking-wider">
                {tag}
              </span>
            ))}
            {recipe.difficulty && (
              <span class="px-3 py-1 bg-slate-200 text-slate-600 rounded-full text-xs font-bold">
                {recipe.difficulty}
              </span>
            )}
          </div>
        )}
      </div>

      <!-- Time chips -->
      {timeItems.length > 0 && (
        <div class="grid gap-2 rounded-xl bg-primary/5 border border-primary/10 p-4 mb-6" style={`grid-template-columns: repeat(${timeItems.length}, 1fr)`}>
          {timeItems.map((item, i) => (
            <div class:list={[
              'flex flex-col items-center justify-center',
              i < timeItems.length - 1 && 'border-r border-primary/10',
            ]}>
              <span class="text-[10px] font-bold text-primary uppercase">{item.label}</span>
              <span class="text-sm font-bold">{item.value}</span>
            </div>
          ))}
        </div>
      )}

      <!-- Macro calculator -->
      {hasMacros ? (
        <div class="mb-6">
          <MacroCalculator
            client:load
            baseWeight={recipe.basePortionWeight!}
            baseCalories={recipe.baseCalories!}
            baseProtein={recipe.baseProtein!}
            baseCarbs={recipe.baseCarbs!}
            baseFat={recipe.baseFat!}
          />
        </div>
      ) : recipe.baseCalories && (
        <div class="grid grid-cols-4 gap-3 mb-6">
          <div class="bg-surface p-3 rounded-xl flex flex-col items-center shadow-sm border border-slate-100">
            <span class="text-primary text-xs font-bold">Calorias</span>
            <span class="text-lg font-extrabold">{Math.round(recipe.baseCalories)}</span>
            <span class="text-[10px] text-slate-500 uppercase">kcal</span>
          </div>
          <div class="bg-surface p-3 rounded-xl flex flex-col items-center shadow-sm border border-slate-100">
            <span class="text-primary text-xs font-bold">Proteina</span>
            <span class="text-lg font-extrabold">{recipe.baseProtein}g</span>
            <span class="text-[10px] text-slate-500 uppercase">prot</span>
          </div>
          <div class="bg-surface p-3 rounded-xl flex flex-col items-center shadow-sm border border-slate-100">
            <span class="text-primary text-xs font-bold">HC</span>
            <span class="text-lg font-extrabold">{recipe.baseCarbs}g</span>
            <span class="text-[10px] text-slate-500 uppercase">carbs</span>
          </div>
          <div class="bg-surface p-3 rounded-xl flex flex-col items-center shadow-sm border border-slate-100">
            <span class="text-primary text-xs font-bold">Grasas</span>
            <span class="text-lg font-extrabold">{recipe.baseFat}g</span>
            <span class="text-[10px] text-slate-500 uppercase">fat</span>
          </div>
        </div>
      )}

      <!-- Instructions -->
      <section class="mb-6">
        <h2 class="text-xl font-extrabold mb-5 flex items-center gap-2">
          <span class="material-symbols-outlined text-primary">restaurant</span>
          Preparacion
        </h2>
        <div class="space-y-6">
          {instructions.map((step, i) =>
            step.startsWith('[') ? (
              <h3 class="font-bold text-primary mt-6">{step.replace(/[\[\]]/g, '')}</h3>
            ) : (
              <div class="flex gap-4">
                <span class="flex-shrink-0 size-8 bg-primary text-white rounded-full flex items-center justify-center font-bold text-sm shadow-sm shadow-primary/30">
                  {i + 1}
                </span>
                <p class="text-slate-600 text-sm leading-relaxed pt-1">{step}</p>
              </div>
            )
          )}
        </div>
      </section>
    </div>

    <!-- Right column (mobile: full width, desktop: 5 cols) -->
    <div class="md:col-span-5 space-y-6">
      <!-- Ingredients -->
      <section class="bg-surface p-6 rounded-xl shadow-sm border border-slate-200">
        <h2 class="text-xl font-extrabold mb-4 flex items-center gap-2">
          <span class="material-symbols-outlined text-primary">shopping_basket</span>
          Ingredientes
        </h2>
        {ingredients.map((group) => (
          <div class="mb-4 last:mb-0">
            {group.group && (
              <h3 class="text-xs font-bold text-primary uppercase tracking-wider mb-2">{group.group}</h3>
            )}
            <ul class="space-y-2.5">
              {group.items.map((item) => (
                <li class="flex items-center gap-3 pb-2.5 border-b border-slate-100 last:border-0 last:pb-0">
                  <span class="size-1.5 rounded-full bg-primary/40 shrink-0"></span>
                  <span class="text-sm text-slate-700">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </section>

      <!-- Notes -->
      {notes && notes.length > 0 && (
        <section class="bg-primary/5 p-5 rounded-xl border-l-4 border-primary">
          <h3 class="text-lg font-bold text-primary mb-3 flex items-center gap-2">
            <span class="material-symbols-outlined">lightbulb</span>
            Notas
          </h3>
          <ul class="space-y-2">
            {notes.map((note) => (
              <li class="text-sm text-slate-600 leading-relaxed pl-4 relative before:content-[''] before:absolute before:left-0 before:top-2 before:size-1.5 before:rounded-full before:bg-primary/30">
                {note}
              </li>
            ))}
          </ul>
        </section>
      )}

      <!-- Source -->
      {recipe.sourceUrl && (
        <a
          href={recipe.sourceUrl}
          target="_blank"
          rel="noopener"
          class="flex items-center gap-2 text-sm text-slate-500 hover:text-primary transition-colors"
        >
          <span class="material-symbols-outlined text-base">open_in_new</span>
          Fuente: {recipe.sourceName || 'Ver original'}
        </a>
      )}
    </div>
  </div>
</Layout>
