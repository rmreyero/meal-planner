---
import Layout from '@/layouts/Layout.astro';
import MacroCalculator from '@/components/MacroCalculator.vue';
import FavoriteButton from '@/components/FavoriteButton.vue';
import PhotoUpload from '@/components/PhotoUpload.vue';
import IconArrowBack from '~icons/material-symbols/arrow-back';
import IconRestaurant from '~icons/material-symbols/restaurant';
import IconShoppingBasket from '~icons/material-symbols/shopping-basket-outline';
import IconLightbulb from '~icons/material-symbols/lightbulb-outline';
import IconOpenInNew from '~icons/material-symbols/open-in-new';
import type { IngredientGroup } from '@db/schema';
import { getRecipeBySlug } from '@/services/recipes';

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/');
}

const recipe = getRecipeBySlug(slug);

if (!recipe) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

const ingredients = recipe.ingredients as IngredientGroup[];
const instructions = recipe.instructions as string[];
const notes = recipe.notes as string[] | null;
const hasMacros = recipe.baseCalories && recipe.basePortionWeight;
const tags = (recipe.tags as string[] | null) ?? [];

const timeItems = [
  recipe.prepTime && { label: 'Prep', value: recipe.prepTime },
  recipe.cookTime && { label: 'Coccion', value: recipe.cookTime },
  recipe.totalTime && { label: 'Total', value: recipe.totalTime },
].filter(Boolean) as { label: string; value: string }[];

let stepCounter = 0;
---

<Layout title={recipe.name} hideMobileHeader>
  <!-- Mobile back + favorite -->
  <nav class="flex items-center -mx-4 px-4 py-2 justify-between md:hidden">
    <a href="/" class="flex size-10 items-center justify-center rounded-full hover:bg-primary/10 transition-colors">
      <IconArrowBack class="w-6 h-6" />
    </a>
    <FavoriteButton client:load recipeId={recipe.id} initial={!!recipe.isFavorite} />
  </nav>

  <!-- Hero image / Photo upload -->
  <PhotoUpload client:idle recipeId={recipe.id} currentPhoto={recipe.photoPath ?? undefined} />

  <!-- Desktop: grid layout -->
  <div class="md:grid md:grid-cols-12 md:gap-8 md:mt-6">
    <!-- Left column -->
    <div class="md:col-span-8">
      <!-- Title & meta -->
      <div class="pt-4 md:pt-0 pb-2">
        <div class="flex items-start justify-between">
          <h1 class="text-3xl font-extrabold leading-tight">{recipe.name}</h1>
          <div class="hidden md:block">
            <FavoriteButton client:load recipeId={recipe.id} initial={!!recipe.isFavorite} />
          </div>
        </div>

        <div class="flex flex-wrap gap-2 mt-3">
          {tags.map((tag) => (
            <span class="px-3 py-1 bg-primary/10 text-primary rounded-full text-xs font-bold uppercase tracking-wider">
              {tag}
            </span>
          ))}
          {recipe.difficulty && (
            <span class="px-3 py-1 bg-slate-200 text-slate-600 rounded-full text-xs font-bold">
              {recipe.difficulty}
            </span>
          )}
          {recipe.sourceName && (
            <a
              href={recipe.sourceUrl || '#'}
              target={recipe.sourceUrl ? '_blank' : undefined}
              rel={recipe.sourceUrl ? 'noopener' : undefined}
              class="px-3 py-1 bg-slate-200 text-slate-600 rounded-full text-xs font-bold italic hover:text-primary transition-colors"
            >
              {recipe.sourceName}
            </a>
          )}
        </div>
      </div>

      <!-- Time chips -->
      {timeItems.length > 0 && (
        <div class="grid gap-2 rounded-xl bg-primary/5 p-4 my-4" style={`grid-template-columns: repeat(${timeItems.length}, 1fr)`}>
          {timeItems.map((item, i) => (
            <div class:list={[
              'flex flex-col items-center justify-center',
              i < timeItems.length - 1 && 'border-r border-primary/10',
            ]}>
              <span class="text-[10px] font-bold text-primary uppercase">{item.label}</span>
              <span class="text-sm font-bold">{item.value}</span>
            </div>
          ))}
        </div>
      )}

      <!-- Macro calculator -->
      {hasMacros ? (
        <div class="py-6">
          <MacroCalculator
            client:idle
            baseWeight={recipe.basePortionWeight!}
            baseCalories={recipe.baseCalories!}
            baseProtein={recipe.baseProtein!}
            baseCarbs={recipe.baseCarbs!}
            baseFat={recipe.baseFat!}
          />
        </div>
      ) : recipe.baseCalories && (
        <div class="grid grid-cols-4 gap-3 py-6">
          <div class="bg-white p-3 rounded-xl flex flex-col items-center shadow-sm border border-slate-100">
            <span class="text-primary text-xs font-bold">Calorias</span>
            <span class="text-lg font-extrabold">{Math.round(recipe.baseCalories)}</span>
            <span class="text-[10px] text-slate-500 uppercase">kcal</span>
          </div>
          <div class="bg-white p-3 rounded-xl flex flex-col items-center shadow-sm border border-slate-100">
            <span class="text-primary text-xs font-bold">Proteina</span>
            <span class="text-lg font-extrabold">{recipe.baseProtein}g</span>
            <span class="text-[10px] text-slate-500 uppercase">prot</span>
          </div>
          <div class="bg-white p-3 rounded-xl flex flex-col items-center shadow-sm border border-slate-100">
            <span class="text-primary text-xs font-bold">HC</span>
            <span class="text-lg font-extrabold">{recipe.baseCarbs}g</span>
            <span class="text-[10px] text-slate-500 uppercase">carbs</span>
          </div>
          <div class="bg-white p-3 rounded-xl flex flex-col items-center shadow-sm border border-slate-100">
            <span class="text-primary text-xs font-bold">Grasas</span>
            <span class="text-lg font-extrabold">{recipe.baseFat}g</span>
            <span class="text-[10px] text-slate-500 uppercase">fat</span>
          </div>
        </div>
      )}

      <!-- Instructions -->
      <section class="py-8">
        <h2 class="text-xl font-bold mb-6 flex items-center gap-2">
          <IconRestaurant class="w-6 h-6 text-primary" />
          Paso a Paso
        </h2>
        <div class="space-y-8">
          {instructions.map((step) => {
            if (step.startsWith('[')) {
              return (
                <h3 class="font-bold text-primary mt-2">{step.replace(/[\[\]]/g, '')}</h3>
              );
            }
            stepCounter++;
            return (
              <div class="flex gap-4">
                <span class="flex-shrink-0 size-8 bg-primary text-white rounded-full flex items-center justify-center font-bold text-sm shadow-sm shadow-primary/30">
                  {stepCounter}
                </span>
                <p class="text-slate-600 text-sm leading-relaxed pt-1">{step}</p>
              </div>
            );
          })}
        </div>
      </section>
    </div>

    <!-- Right column -->
    <div class="md:col-span-4 space-y-6">
      <!-- Ingredients -->
      <section class="bg-white rounded-t-3xl md:rounded-xl shadow-inner md:shadow-sm p-6 -mx-4 md:mx-0 md:border md:border-slate-200">
        <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
          <IconShoppingBasket class="w-6 h-6 text-primary" />
          Ingredientes
        </h2>
        {ingredients.map((group) => (
          <div class="mb-4 last:mb-0">
            {group.group && (
              <h3 class="text-xs font-bold text-primary uppercase tracking-wider mb-3">{group.group}</h3>
            )}
            <div class="space-y-4">
              {group.items.map((item) => (
                <label class="flex items-center gap-3 group cursor-pointer">
                  <input type="checkbox" class="rounded border-slate-300 text-primary focus:ring-primary size-5 shrink-0" />
                  <span class="text-slate-700 font-medium text-sm group-has-checked:line-through group-has-checked:text-slate-400 transition-colors">{item}</span>
                </label>
              ))}
            </div>
          </div>
        ))}
      </section>

      <!-- Notes -->
      {notes && notes.length > 0 && (
        <section class="bg-primary/5 p-6 rounded-2xl border border-primary/10 -mx-4 md:mx-0">
          <h3 class="text-lg font-bold mb-3 flex items-center gap-2 text-primary">
            <IconLightbulb class="w-6 h-6" />
            Notas y Consejos
          </h3>
          <ul class="space-y-2 list-disc list-inside text-sm text-slate-700 leading-relaxed">
            {notes.map((note) => (
              <li>{note}</li>
            ))}
          </ul>
        </section>
      )}

      <!-- Source (fallback if not shown in tags) -->
      {recipe.sourceUrl && !recipe.sourceName && (
        <a
          href={recipe.sourceUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 text-sm text-slate-500 hover:text-primary transition-colors -mx-4 md:mx-0 px-4 md:px-0"
        >
          <IconOpenInNew class="w-4 h-4" />
          Ver receta original
        </a>
      )}
    </div>
  </div>
</Layout>
