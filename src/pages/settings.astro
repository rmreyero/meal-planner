---
import Layout from '../layouts/Layout.astro';
import MacroTargetsForm from '../components/MacroTargetsForm.vue';
import IconTarget from '~icons/material-symbols/target';
---

<Layout title="Ajustes">
  <h1 class="text-2xl font-extrabold tracking-tight mb-6">Ajustes</h1>
  <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
    <IconTarget class="w-6 h-6 text-primary" />
    Objetivos de macros
  </h2>
  <MacroTargetsForm client:idle />
</Layout>
