---
interface Props {
  title: string;
  description?: string;
  hideMobileHeader?: boolean;
}

const { title, description = 'Planifica tus comidas y controla tus macros.', hideMobileHeader = false } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin);

const navItems = [
  { href: '/', label: 'Recetas', icon: 'menu_book' },
  { href: '/planner', label: 'Planner', icon: 'calendar_today' },
  { href: '/settings', label: 'Ajustes', icon: 'tune' },
] as const;

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL.href} />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <title>{title} | Meal Planner</title>
  </head>
  <body class="bg-bg text-slate-900 min-h-screen pb-20 md:pb-0">
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[100] focus:bg-primary focus:text-white focus:px-4 focus:py-2 focus:rounded-lg focus:text-sm focus:font-bold">Saltar al contenido</a>
    <!-- Mobile top bar -->
    <header class:list={["md:hidden sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-primary/10 px-4 py-2.5", hideMobileHeader && "hidden"]}>
      <a href="/" class="flex items-center gap-2">
        <div class="bg-primary p-1 rounded-md text-white">
          <span aria-hidden="true" class="material-symbols-outlined text-lg">restaurant</span>
        </div>
        <span class="text-base font-extrabold tracking-tight">Meal <span class="text-primary">Planner</span></span>
      </a>
    </header>

    <!-- Desktop top nav -->
    <header class="hidden md:block sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-primary/10">
      <div class="max-w-5xl mx-auto px-6 py-3 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2.5">
          <div class="bg-primary p-1.5 rounded-lg text-white">
            <span aria-hidden="true" class="material-symbols-outlined text-xl">restaurant</span>
          </div>
          <span class="text-lg font-extrabold tracking-tight">Meal <span class="text-primary">Planner</span></span>
        </a>
        <nav class="flex items-center gap-8">
          {navItems.map(({ href, label, icon }) => {
            const isActive = href === '/' ? currentPath === '/' : currentPath.startsWith(href);
            return (
              <a
                href={href}
                class:list={[
                  'flex items-center gap-1.5 text-sm font-medium pb-0.5 transition-colors',
                  isActive
                    ? 'text-primary font-bold border-b-2 border-primary'
                    : 'text-slate-500 hover:text-primary',
                ]}
              >
                <span aria-hidden="true" class="material-symbols-outlined text-lg">{icon}</span>
                {label}
              </a>
            );
          })}
        </nav>
      </div>
    </header>

    <main id="main" class="max-w-5xl mx-auto px-4 py-6">
      <slot />
    </main>

    <!-- Mobile bottom nav -->
    <nav class="md:hidden fixed bottom-0 left-0 right-0 border-t border-border bg-white/90 backdrop-blur-md px-6 pb-5 pt-2 z-50">
      <div class="flex justify-around items-center max-w-md mx-auto">
        {navItems.map(({ href, label, icon }) => {
          const isActive = href === '/' ? currentPath === '/' : currentPath.startsWith(href);
          return (
            <a
              href={href}
              class:list={[
                'flex flex-col items-center gap-0.5 transition-colors',
                isActive ? 'text-primary' : 'text-slate-400',
              ]}
            >
              <span aria-hidden="true" class="material-symbols-outlined">{icon}</span>
              <span class="text-[10px] font-bold uppercase tracking-widest">{label}</span>
            </a>
          );
        })}
      </div>
    </nav>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
